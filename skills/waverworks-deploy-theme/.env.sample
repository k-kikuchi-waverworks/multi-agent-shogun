# waverworks-deploy-theme .env.sample
# 本ファイルはgit commit対象（プレースホルダのみ）
# 実値は .env（git-ignored）に記入。絶対にベタ書きしない。
#
# セットアップ:
#   cp skills/waverworks-deploy-theme/.env.sample skills/waverworks-deploy-theme/.env
# 次に .env を編集して <...> を実値で置き換える。

# --- WPMUDEV SSH 接続 ---
WAVERWORKS_SSH_HOST=<your-wpmudev-host>
WAVERWORKS_SSH_USER_STG=<your-staging-ssh-user>
WAVERWORKS_SSH_USER_PRD=<your-production-ssh-user>

# --- 秘密鍵の絶対パス (Windows パス) ---
# 1組共用の場合は STG/PRD に同値を記入
WAVERWORKS_SSH_KEY_STG=<absolute-path-to-staging-ed25519-private-key>
WAVERWORKS_SSH_KEY_PRD=<absolute-path-to-production-ed25519-private-key>

# --- テーマ配置パス (リモートサーバー側絶対パス) ---
WAVERWORKS_THEME_PATH_STG=<staging-theme-absolute-path>
WAVERWORKS_THEME_PATH_PRD=<production-theme-absolute-path>

# --- WordPress ルートパス (WP-CLI 用) ---
# 共通パスがある場合は WAVERWORKS_WP_ROOT に記入 (STG/PRD 個別優先)
WAVERWORKS_WP_ROOT=<wp-root-absolute-path>
# WAVERWORKS_WP_ROOT_STG=<staging-wp-root-path>
# WAVERWORKS_WP_ROOT_PRD=<production-wp-root-path>

# --- サイト URL (HTTP 疎通確認用、任意) ---
# WAVERWORKS_SITE_URL_STG=https://waverworks.staging.tempurl.host
# WAVERWORKS_SITE_URL_PRD=https://waverworks.co.jp

# --- ファイル権限 (空白でフォールバック: www-data:www-data 755/644) ---
WAVERWORKS_THEME_OWNER=
WAVERWORKS_THEME_GROUP=
WAVERWORKS_THEME_MODE_FILE=
WAVERWORKS_THEME_MODE_DIR=

# --- テーマソースパス (Windows ローカル) ---
WAVERWORKS_THEME_LOCAL=<windows-local-theme-source-path>

# --- WPMUDEV Snapshot API (Production Snapshot 自動取得用、任意) ---
# 未設定の場合は WP-CLI または手動確認プロンプトにフォールバック
# WAVERWORKS_WPMUDEV_API_KEY=<wpmudev-hub-api-key>
# WAVERWORKS_WPMUDEV_SITE_ID_PRD=<production-site-id>
